# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Microsoft Fabric - Data Lake URLs
# MCP Server (preferred)
FABRIC_MCP_URL=https://api.fabric.microsoft.com/v1/mcp/workspaces/be2ea36c-3935-42e9-9a26-45e22db69941/dataagents/89444cc8-c862-448b-9541-7390574a151b/agent

# OpenAI-compatible endpoint (fallback)
FABRIC_OPENAI_URL=https://api.fabric.microsoft.com/v1/workspaces/be2ea36c-3935-42e9-9a26-45e22db69941/dataagents/89444cc8-c862-448b-9541-7390574a151b/aiassistant/openai

# Azure AD - Autenticación
# Estrategia 1: Token de usuario (desarrollo)
AZURE_ACCESS_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGc...

# Estrategia 2: Service Principal (producción/RunBook)
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Configuración de reportes
REPORT_FROM_EMAIL=noreply@tiendas3b.com.bo
REPORT_RECIPIENTS=gerente@tiendas3b.com.bo,analista@tiendas3b.com.bo

# Modo de ejecución (opcional: "chat" | "scheduled")
# Si no se especifica, se detecta por argumentos
MODE=chat

# Modelo LLM a usar (default: claude-haiku-4-5-20251001 para costo bajo, sonnet para balance)
# Opciones: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-8
LLM_MODEL=claude-haiku-4-5-20251001
# LLM_MODEL=claude-sonnet-4-6
